# Set default behaviour, in case users don't have core.autocrlf set.
* text=auto

# Explicitly declare text files we want to always be normalized and converted
# to native line endings on checkout.
*.json text
*.cs text diff=csharp
*.csv text
*.properties text
*.txt text
*.xml text

#iOS Plugins
*.h text eol=lf
*.m text eol=lf
*.mm text eol=lf
*.strings text eol=lf
*.swift text eol=lf
*.swiftdoc text eol=lf
*.swiftinterface text eol=lf
*.plist text eol=lf

#AndroidPerformanceTuner generate files with LF
dev_tuningfork.proto text eol=lf
DevTuningfork.cs text eol=lf

#Unity save own files with LF, even on Windows   (except *.shader)
GvhProjectSettings.xml text eol=lf
*.anim text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.spriteatlas text eol=lf
*.shader text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.bytes binary
*.fbx binary
*.dll binary
*.png binary
*.png~ binary
*.jpg binary
*.jpeg binary
*.obj binary
*.mp4 binary
*.pdb binary
*.psd binary
*.tif binary
*.tiff binary
*.tga binary
*.wav binary

# Excludes
.gitattributes export-ignore
.gitignore export-ignore
.gitmodules export-ignore
